{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "muhammad/laravel-smart-dev-kit",
    "type": "project",
    "description": "Laravel Smart Dev Kit — Rapid API development starter with Clean Architecture, smart code generation, and full Spatie ecosystem integration.",
    "keywords": ["laravel", "api", "crud", "code-generator", "clean-architecture", "spatie"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.3",
        "laravel/socialite": "^5.26",
        "laravel/tinker": "^3.0",
        "muhammad/easy-dev": "@dev",
        "nuwave/lighthouse": "^6.66",
        "nwidart/laravel-modules": "^13.0",
        "php-open-source-saver/jwt-auth": "^2.1",
        "spatie/laravel-activitylog": "^5.0",
        "spatie/laravel-data": "^4.0",
        "spatie/laravel-medialibrary": "^11.21",
        "spatie/laravel-permission": "^7.3",
        "spatie/laravel-query-builder": "^7.2",
        "spatie/laravel-translatable": "^6.13",
        "stancl/tenancy": "^3.10"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.57",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.4.1",
        "pestphp/pest-plugin-laravel": "^4.1.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Illuminate\\Database\\Eloquent\\Attributes\\": "app/Framework/Attributes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "EasyDev\\Laravel\\Tests\\": "packages/muhammad/easy-dev/tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "./packages/muhammad/easy-dev"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}
